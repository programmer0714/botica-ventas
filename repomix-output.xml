/* =====================================================
   BOTICA NOVA SALUD — Estilos Globales
   ===================================================== */
@import './variables.css';

/* === LAYOUT PRINCIPAL === */
.app-layout { display: flex; height: 100vh; overflow: hidden; }

/* === BOTONES === */
.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 9px 18px; border: none; border-radius: var(--radius-md);
  font-size: 13.5px; font-weight: 500; transition: all .18s ease;
}
.btn-primary {
  position: relative;
  overflow: hidden;
  background: var(--gradient-primary);
  color: rgba(255,255,255,1);
  box-shadow: 0 4px 12px rgba(153, 6, 6, 0.2), inset 0 1px 1px rgba(255,255,255,0.4);
  border: 1px solid rgba(153,27,27,1);
}
.btn-primary::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.4) 50%, rgba(255,255,255,0) 100%);
  transform: skewX(-25deg);
  transition: all 0.75s ease;
}
.btn-primary:hover {
  background: linear-gradient(135deg, rgba(220,38,38,1) 0%, rgba(185,28,28,1) 100%);
  box-shadow: 0 6px 16px rgba(153, 6, 6, 0.3), inset 0 1px 2px rgba(255,255,255,0.5);
  transform: translateY(-1px);
}
.btn-primary:hover::after {
  left: 200%;
}
.btn-danger {
  background: var(--gradient-danger);
  color: rgba(255,255,255,1);
  box-shadow: 0 2px 8px rgba(192,57,43,0.25);
}
.btn-outline {
  background: rgba(255,255,255,1);
  border: 1px solid var(--color-border);
  color: var(--color-text-2);
}
.btn-outline:hover { border-color: var(--color-primary); color: var(--color-primary); }
.btn-sm { padding: 6px 12px; font-size: 12px; }
.btn-icon { padding: 8px; border-radius: var(--radius-md); }

/* === CARDS === */
.card {
  background: linear-gradient(145deg, rgba(255,255,255,1) 0%, rgba(248,250,252,1) 100%);
  border-radius: var(--radius-lg);
  border: 1px solid rgba(226,232,240,0.8);
  box-shadow: 0 4px 16px rgba(203,213,225,0.2), inset 0 1px 0 rgba(255,255,255,1);
  padding: 20px;
}
.card-header {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: 16px;
}
.card-title { font-size: 14px; font-weight: 600; color: var(--color-text); }

/* === FORMULARIOS === */
.form-group { margin-bottom: 14px; }
.form-label {
  display: block; font-size: 12px; font-weight: 500;
  color: var(--color-text-2); margin-bottom: 5px;
}
.form-control {
  width: 100%; padding: 9px 12px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  background: rgba(255,255,255,1);
  color: var(--color-text);
  font-size: 13.5px; outline: none; transition: all .15s;
}
.form-control:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(185,28,28,0.1);
}
.form-row { display: grid; gap: 12px; }
.form-row.cols-2 { grid-template-columns: 1fr 1fr; }
.form-row.cols-3 { grid-template-columns: 1fr 1fr 1fr; }

/* === TABLA === */
.table-wrapper { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
thead th {
  text-align: center; padding: 10px 14px;
  font-size: 11px; font-weight: 600; text-transform: uppercase;
  letter-spacing: .5px; color: var(--color-text-3);
  border-bottom: 1px solid var(--color-border);
  background: rgba(244,246,245,0.6);
}
tbody td { 
  text-align: center; 
  padding: 12px 14px; 
  border-bottom: 1px solid var(--color-border); 
  color: var(--color-text-2); 
}
tbody tr:last-child td { border-bottom: none; }
tbody tr:hover td { background: rgba(203,213,225,0.15); }

/* === BADGES === */
.badge {
  display: inline-block; padding: 3px 10px;
  border-radius: var(--radius-full); font-size: 11px; font-weight: 500;
}
.badge-green  { background: rgba(13,122,95,0.12);  color: rgba(10,99,80,1); }
.badge-red    { background: rgba(192,57,43,0.1);   color: rgba(160,40,30,1); }
.badge-yellow { background: rgba(240,165,0,0.12);  color: rgba(160,110,0,1); }
.badge-blue   { background: rgba(26,111,168,0.1);  color: rgba(18,85,130,1); }
.badge-gray   { background: rgba(138,160,155,0.15); color: rgba(74,101,96,1); }

/* === GRIDS === */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
.grid-4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; }

/* === UTILIDADES === */
.flex         { display: flex; }
.flex-center  { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.gap-8  { gap: 8px; }
.gap-12 { gap: 12px; }
.gap-16 { gap: 16px; }
.mt-16  { margin-top: 16px; }
.mb-16  { margin-bottom: 16px; }
.text-sm  { font-size: 12px; }
.text-muted { color: var(--color-text-3); }
.font-title { font-family: var(--font-title); }

/* === IMAGEN PLACEHOLDER === */
.img-placeholder {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  background: var(--gradient-hero);
  border: 1px dashed rgba(203,213,225,0.8);
  border-radius: var(--radius-md);
  color: var(--color-text-3);
  font-size: 11px; gap: 4px;
}
.img-placeholder span { font-size: 24px; }
</file>

<file path="frontend/src/styles/variables.css">
/* =====================================================
   BOTICA NOVA SALUD — Variables Globales
   Todos los colores en rgba con gradientes
   ===================================================== */

:root {
  /* === COLORES PRIMARIOS (Rojo Profundo) === */
  --color-primary:        rgba(185, 28, 28, 1);
  --color-primary-dark:   rgba(153, 27, 27, 1);
  --color-primary-light:  rgba(185, 28, 28, 0.12);
  --color-primary-mid:    rgba(185, 28, 28, 0.35);

  /* === COLORES SIDEBAR (Gris/Plata Oscuro) === */
  --color-sidebar:        rgba(30, 41, 59, 1);
  --color-sidebar-hover:  rgba(203, 213, 225, 0.15);
  --color-sidebar-active: rgba(185, 28, 28, 0.35);

  /* === FONDO (Plomo / Gris) === */
  --color-bg:             rgba(226, 232, 240, 1); /* Slate 200 - Plomo */
  --color-card:           rgba(255, 255, 255, 1);
  --color-card-hover:     rgba(241, 245, 249, 1);

  /* === BORDES (Plateado - Silver) === */
  --color-border:         rgba(203, 213, 225, 1);
  --color-border-light:   rgba(226, 232, 240, 1);

  /* === TEXTOS === */
  --color-text:           rgba(15, 23, 42, 1);     /* Slate 900 - Muy oscuro */
  --color-text-2:         rgba(30, 41, 59, 1);     /* Slate 800 - Más legible */
  --color-text-3:         rgba(51, 65, 85, 1);     /* Slate 700 - Subtítulos más claros pero visibles */

  /* === ACENTO (Plata) === */
  --color-accent:         rgba(148, 163, 184, 1);
  --color-accent-light:   rgba(203, 213, 225, 0.3);

  /* === ROJO (Alertas/Peligro) === */
  --color-danger:         rgba(220, 38, 38, 1);
  --color-danger-light:   rgba(220, 38, 38, 0.1);

  /* === AZUL (Info) === */
  --color-info:           rgba(56, 189, 248, 1);
  --color-info-light:     rgba(56, 189, 248, 0.1);

  /* === VERDE ÉXITO === */
  --color-success:        rgba(16, 185, 129, 1);
  --color-success-light:  rgba(16, 185, 129, 0.1);

  /* === GRADIENTES === */
  --gradient-primary:     linear-gradient(135deg, rgba(120,5,5,1) 0%, rgba(220,38,38,1) 50%, rgba(153,6,6,1) 100%);
  --gradient-sidebar:     linear-gradient(180deg, rgba(30,41,59,1) 0%, rgba(15,23,42,1) 100%);
  --gradient-card:        linear-gradient(135deg, rgba(255,255,255,1) 0%, rgba(248,250,252,1) 100%);
  --gradient-hero:        linear-gradient(135deg, rgba(226,232,240,0.5) 0%, rgba(248,250,252,1) 100%);
  --gradient-danger:      linear-gradient(135deg, rgba(220,38,38,1) 0%, rgba(185,28,28,1) 100%);
  --gradient-accent:      linear-gradient(135deg, rgba(203,213,225,1) 0%, rgba(148,163,184,1) 100%);
  --gradient-blue:        linear-gradient(135deg, rgba(56,189,248,1) 0%, rgba(2,132,199,1) 100%);
  --gradient-stat-green:  linear-gradient(135deg, rgba(185,28,28,0.15) 0%, rgba(185,28,28,0.05) 100%);
  --gradient-stat-red:    linear-gradient(135deg, rgba(220,38,38,0.15) 0%, rgba(220,38,38,0.05) 100%);
  --gradient-stat-yellow: linear-gradient(135deg, rgba(203,213,225,0.3) 0%, rgba(203,213,225,0.1) 100%);
  --gradient-stat-blue:   linear-gradient(135deg, rgba(56,189,248,0.15) 0%, rgba(56,189,248,0.05) 100%);


      `UPDATE productos SET nombre=?, id_laboratorio=?, id_categoria=?, id_presentacion=?,
       precio=?, stock=?, stock_minimo=?, fecha_vencimiento=?, estado=?
       WHERE id_producto = ?`,
      [nombre, id_laboratorio, id_categoria, id_presentacion, precio, stock, stock_minimo, fecha_vencimiento, estado, id]
    );
    res.json({ ok: true, mensaje: 'Producto actualizado correctamente' });

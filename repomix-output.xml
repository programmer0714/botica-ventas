      <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
        stroke={icono.color} strokeWidth="2"
        strokeLinecap="round" strokeLinejoin="round">
        <path d={icono.path} />
      </svg>
    </div>
  )
}


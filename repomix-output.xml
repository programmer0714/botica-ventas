  --shadow-md:   0 4px 16px rgba(203,213,225,0.5);
  --shadow-lg:   0 8px 32px rgba(148,163,184,0.4);
  --shadow-card: 0 4px 16px rgba(203,213,225,0.25), inset 0 1px 0 rgba(255,255,255,1);

  /* === TIPOGRAFÍA === */
